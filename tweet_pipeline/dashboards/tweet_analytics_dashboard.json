{
  "datasets": [
    {
      "name": "5c75bd1f",
      "displayName": "total_tweets",
      "queryLines": [
        "SELECT COUNT(*) AS total_tweets\r\n",
        "FROM workspace.default.tweets_bronze;"
      ]
    },
    {
      "name": "812778b7",
      "displayName": "tweets_with_mentions",
      "queryLines": [
        "SELECT COUNT(*) AS tweets_with_mentions\r\n",
        "FROM workspace.default.tweets_silver\r\n",
        "WHERE mention IS NOT NULL;"
      ]
    },
    {
      "name": "7460646b",
      "displayName": "tweets_without_mentions",
      "queryLines": [
        "SELECT COUNT(*) AS tweets_without_mentions\r\n",
        "FROM workspace.default.tweets_silver\r\n",
        "WHERE mention IS NULL;"
      ]
    },
    {
      "name": "6a46293c",
      "displayName": "top_users",
      "queryLines": [
        "SELECT user, COUNT(*) AS tweet_count\r\n",
        "FROM workspace.default.tweets_bronze\r\n",
        "GROUP BY user\r\n",
        "ORDER BY tweet_count DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "0f089af9",
      "displayName": "top_positive_mentions",
      "queryLines": [
        "SELECT mention, positive_mentions\r\n",
        "FROM workspace.default.gold_tweet_aggregations\r\n",
        "ORDER BY positive_mentions DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "3eacdb5e",
      "displayName": "top_negative_mentions",
      "queryLines": [
        "SELECT mention, negative_mentions\r\n",
        "FROM workspace.default.gold_tweet_aggregations\r\n",
        "ORDER BY negative_mentions DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "6adddb50",
      "displayName": "Untitled dataset",
      "queryLines": [
        "spark.table(\"workspace.default.tweets_bronze\").printSchema()"
      ]
    }
  ],
